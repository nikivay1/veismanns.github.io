---
import type { Experience } from '../i18n/content';

interface Props {
  job: Experience;
  index: number;
  technologiesLabel: string;
}

const { job, index, technologiesLabel } = Astro.props;
---

<article class="grid grid-cols-[2rem_minmax(0,1fr)] gap-x-4 border-b border-line py-[clamp(2.5rem,5vw,4.5rem)]">
  <div class="pt-1 font-mono text-[0.68rem] font-bold leading-none text-signal" aria-hidden="true">0{index + 1}</div>

  <div>
    <div class="mb-6 flex items-start justify-between gap-5 max-sm:block">
      <header>
        <h3 class="m-0 text-[clamp(2rem,4vw,4rem)] leading-[0.9] font-bold tracking-[-0.06em]">{job.company}</h3>
        <p class="mt-3 mb-0 font-mono text-[0.68rem] font-bold uppercase leading-[1.3] text-muted">{job.role}</p>
      </header>
      <div class="shrink-0 text-right max-sm:mt-4 max-sm:flex max-sm:justify-between max-sm:text-left">
        <p class="job-meta">{job.period}</p>
        <p class="job-meta text-muted">{job.location}</p>
      </div>
    </div>

    <p class="max-w-3xl text-[1.05rem] leading-[1.5]">{job.summary}</p>

    <div class="my-7 flex flex-wrap gap-x-8 gap-y-5 border-y border-line py-5">
      {job.impact.map(([value, label]) => (
        <div class="flex min-w-[7rem] flex-col border-l-[3px] border-signal pl-3">
          <strong class="text-[clamp(2rem,3.5vw,3.5rem)] leading-[0.9] tracking-[-0.07em]">{value}</strong>
          <span class="mt-2 font-mono text-[0.59rem] font-bold uppercase leading-[1.25]">{label}</span>
        </div>
      ))}
    </div>

    <ul class="my-7 max-w-3xl list-none p-0">
      {job.work.map((item) => (
        <li class="relative border-t border-line py-3 pl-6 leading-[1.45] before:absolute before:left-0 before:text-signal before:content-['↳']">
          {item}
        </li>
      ))}
    </ul>

    <div class="flex flex-wrap gap-1.5" aria-label={technologiesLabel}>
      {job.stack.map((item) => (
        <span class="rounded-full border border-ink px-2.5 py-1.5 font-mono text-[0.62rem] leading-none font-bold">{item}</span>
      ))}
    </div>
  </div>
</article>

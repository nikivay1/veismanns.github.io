---
interface Props {
  index: string;
  title: string;
  id: string;
}

const { index, title, id } = Astro.props;
---

<header class="mb-[clamp(2.75rem,5vw,4rem)]">
  <h2 class="m-0 flex items-center gap-2 font-mono text-[0.65rem] font-bold leading-none tracking-[0.08em] uppercase" id={id}>
    <span>{index}</span>
    <span aria-hidden="true">/</span>
    <span>{title}</span>
  </h2>
</header>

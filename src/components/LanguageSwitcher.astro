---
import type { Locale, LocaleLink } from '../i18n/content';

interface Props {
  label: string;
  currentLocale: Locale;
  links: readonly LocaleLink[];
}

const { label, currentLocale, links } = Astro.props;
---

<div class="flex items-center gap-1" aria-label={label}>
    {links.map((link) => (
      <a
        class:list={[
          'rounded-full px-2.5 py-1.5 font-mono text-[0.64rem] font-bold no-underline transition-colors',
          link.code === currentLocale ? 'bg-signal text-ink' : 'text-[#aaa9a2] hover:text-paper',
        ]}
        href={link.href}
        hreflang={link.code}
        lang={link.code}
        aria-label={link.ariaLabel}
        aria-current={link.code === currentLocale ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
</div>

---
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Locale, LocaleLink, SidebarContent } from '../i18n/content';
import { withBase } from '../utils/url';

interface Props {
  content: SidebarContent;
  locale: Locale;
  localeLinks: readonly LocaleLink[];
}

const { content, locale, localeLinks } = Astro.props;
const cvUrl = withBase('nikita-veisman-cv.pdf');
---

<aside
  class="flex min-h-svh flex-col bg-ink px-[clamp(1.25rem,3.5vw,4rem)] py-[clamp(1.5rem,4vw,4rem)] text-paper lg:sticky lg:top-0 lg:h-svh lg:w-[40vw] lg:self-start lg:overflow-y-auto"
  id="top"
  aria-label={content.ariaLabel}
>
  <div class="flex items-center justify-between border-b border-[#4b4b47] pb-5">
    <a class="text-xl font-black tracking-[-0.06em] no-underline" href="#top" aria-label={content.backToTopLabel}>
      NV<span class="text-signal">°</span>
    </a>
    <a class="nav-link text-paper" href={cvUrl} download>
      {content.downloadLabel} <span aria-hidden="true">↓</span>
    </a>
  </div>

  <header class="py-[clamp(3.5rem,8vh,7rem)]">
    <div class="mb-5 flex items-center gap-2.5 font-mono text-[0.66rem] font-bold uppercase tracking-[0.1em] text-[#bbb9b1]">
      <span class="size-2.5 rounded-full bg-signal shadow-[0_0_0_.25rem_#ff4f2e22]" aria-hidden="true"></span>
      {content.availability}
    </div>
    <h1 class="m-0 text-[clamp(4rem,7vw,8rem)] leading-[0.78] font-black tracking-[-0.085em] lg:text-[clamp(4rem,6.2vw,7rem)]">
      {content.name[0]}<br />{content.name[1]}
    </h1>
    <p class="mt-8 mb-0 text-[clamp(1.5rem,2.5vw,2.5rem)] leading-[0.95] font-bold tracking-[-0.05em]">
      {content.role[0]}<br />{content.role[1]}
    </p>
  </header>

  <div class="grid grid-cols-2 gap-4 border-y border-[#4b4b47] py-5 font-mono text-[0.68rem] font-bold uppercase leading-[1.45]">
    <div>
      <p class="mb-1 text-signal">{content.locationLabel}</p>
      <p>{content.location}</p>
    </div>
    <div>
      <p class="mb-1 text-signal">{content.timeLabel}</p>
      <p>{content.time}</p>
    </div>
  </div>

  <section class="py-7" aria-labelledby="core-skills-title">
    <h2 class="mb-4 font-mono text-[0.65rem] font-bold uppercase tracking-[0.1em] text-[#aaa9a2]" id="core-skills-title">
      {content.coreSkillsLabel}
    </h2>
    <ul class="flex list-none flex-wrap gap-2 p-0">
      {content.coreSkills.map((skill) => (
        <li class="rounded-full border border-[#6d6c67] px-3 py-2 font-mono text-[0.65rem] font-bold leading-none">{skill}</li>
      ))}
    </ul>
  </section>

  <nav class="border-t border-[#4b4b47]" aria-label={content.navigationLabel}>
    {content.navigation.map((item) => (
      <a class="group grid grid-cols-[2.5rem_1fr_auto] items-center border-b border-[#4b4b47] py-3.5 no-underline" href={item.href}>
        <span class="font-mono text-[0.6rem] font-bold text-signal">{item.number}</span>
        <span class="text-lg font-bold tracking-[-0.03em] transition-transform group-hover:translate-x-1.5">{item.label}</span>
        <span class="text-lg text-[#77766f] group-hover:text-signal" aria-hidden="true">↘</span>
      </a>
    ))}
  </nav>

  <div class="mt-auto flex items-center justify-between gap-4 border-y border-[#4b4b47] py-4" aria-label={`${content.socialLabel} / ${content.languageLabel}`}>
    <div class="flex gap-2.5" role="group" aria-label={content.socialLabel}>
      {content.socialLinks.map((link) => <a
        class="group grid size-10 place-items-center rounded-full border border-[#6d6c67] transition-colors hover:border-signal hover:bg-signal hover:text-ink"
        href={link.href}
        target="_blank"
        rel="noreferrer"
        aria-label={link.ariaLabel}
      >
        {link.network === 'telegram' ? <svg class="size-[1.1rem]" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d="M21.8 3.2 18.6 19c-.2 1.1-.9 1.4-1.8.9l-4.9-3.6-2.4 2.3c-.3.3-.5.5-1 .5l.4-5 9.1-8.2c.4-.4-.1-.6-.6-.2L6.2 12.8l-4.8-1.5c-1.1-.3-1.1-1.1.2-1.6L20.4 2.5c.9-.3 1.6.2 1.4.7Z" />
        </svg> : <svg class="size-[1.05rem]" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d="M5.4 7.8H1.8V22h3.6V7.8ZM3.6 2A2.1 2.1 0 1 0 3.6 6.2 2.1 2.1 0 0 0 3.6 2ZM22.2 13.9c0-4.3-2.3-6.3-5.4-6.3a4.7 4.7 0 0 0-4.2 2.3h-.1V7.8H9V22h3.6v-7c0-1.9.4-3.7 2.7-3.7 2.3 0 2.3 2.1 2.3 3.8V22h3.6l1-8.1Z" />
        </svg>}
      </a>)}
    </div>

    <LanguageSwitcher label={content.languageLabel} currentLocale={locale} links={localeLinks} />
  </div>

</aside>

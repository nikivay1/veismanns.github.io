---
import { getRelativeLocaleUrl } from 'astro:i18n';
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from './Sidebar.astro';
import ExperienceSection from './ExperienceSection.astro';
import ToolkitSection from './ToolkitSection.astro';
import AboutSection from './AboutSection.astro';
import ContactSection from './ContactSection.astro';
import SiteFooter from './SiteFooter.astro';
import MobileCvButton from './MobileCvButton.astro';
import { getContent, locales, type Locale, type LocaleLink } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const page = getContent(locale);
const localeNames: Record<Locale, string> = { en: 'English', ru: 'Русский', es: 'Español' };
const localeLinks: readonly LocaleLink[] = locales.map((code) => ({
  code,
  label: code.toUpperCase(),
  href: getRelativeLocaleUrl(code),
  ariaLabel: localeNames[code],
}));
---

<BaseLayout lang={locale} meta={page.meta} alternateLinks={localeLinks}>
  <div class="pb-[calc(5.75rem+env(safe-area-inset-bottom))] min-[641px]:pb-0 lg:flex lg:items-start">
    <Sidebar content={page.sidebar} locale={locale} {localeLinks} />
    <div class="min-w-0 lg:w-[60vw]">
      <main id="main">
        <AboutSection content={page.about} />
        <ExperienceSection content={page.experience} />
        <ToolkitSection content={page.toolkit} />
        <ContactSection content={page.contact} />
      </main>
      <SiteFooter content={page.footer} />
    </div>
  </div>
  <MobileCvButton label={page.sidebar.downloadLabel} />
</BaseLayout>

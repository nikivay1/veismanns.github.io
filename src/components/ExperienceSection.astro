---
import ExperienceCard from './ExperienceCard.astro';
import type { ExperienceContent } from '../i18n/content';

interface Props {
  content: ExperienceContent;
}

const { content } = Astro.props;
---

<section class="section-shell" id="work" aria-labelledby="work-title">
  <header class="section-heading">
    <p class="eyebrow">{content.eyebrow}</p>
    <h2 class="section-title" id="work-title">{content.heading[0]}<br />{content.heading[1]}</h2>
  </header>

  <div class="border-t border-ink">
    {content.jobs.map((job, index) => <ExperienceCard job={job} index={index} technologiesLabel={content.technologiesLabel} />)}
  </div>
</section>

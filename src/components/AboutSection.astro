---
import type { AboutContent } from '../i18n/content';
import SectionHeader from './SectionHeader.astro';

interface Props {
  content: AboutContent;
}

const { content } = Astro.props;
---

<section class="section-shell min-h-svh" id="about" aria-labelledby="about-title">
  <SectionHeader index={content.index} title={content.title} id="about-title" />

  <div>
    <div class="max-w-3xl space-y-5 text-[clamp(1.1rem,1.65vw,1.5rem)] leading-[1.5]">
      {content.summary.map((paragraph, index) => <p class:list={[index > 0 && 'text-muted']}>{paragraph}</p>)}
    </div>

    <div class="mt-[clamp(3rem,7vw,6rem)] grid grid-cols-3 border-y border-ink py-5 max-sm:grid-cols-1 max-sm:gap-5" aria-label={content.impactAriaLabel}>
      {content.impact.map(([value, label]) => <div><strong class="block text-[clamp(2.5rem,5vw,5rem)] leading-none tracking-[-0.07em] text-signal">{value}</strong><span class="impact-label">{label}</span></div>)}
    </div>

    <dl class="mt-[clamp(3rem,6vw,5rem)] grid grid-cols-3 gap-5 border-t border-ink pt-4 max-sm:grid-cols-1">
      {content.facts.map((fact) => <div class="max-[800px]:border-b max-[800px]:border-line max-[800px]:pb-4">
        <dt class="definition-term">{fact.label}</dt>
        <dd class="definition-value">{fact.lines.map((line, index) => <>{index > 0 && <br />}{line}</>)}</dd>
      </div>)}
    </dl>
  </div>
</section>
